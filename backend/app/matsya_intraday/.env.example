# Separate writable PostgreSQL database for validated normal-session minute candles.
MATSYA_INTRADAY_DATABASE_URL=postgresql://intraday_user:replace_me@127.0.0.1:5432/matsya_intraday

# Existing authoritative daily database. Use a read-only database role.
MATSYA_DAILY_DATABASE_URL=postgresql://daily_reader:replace_me@127.0.0.1:5432/matsya

# Approved first trusted normal-session minute date; configurable but must not be moved earlier
# without another validation pilot.
MATSYA_INTRADAY_TRUSTED_START_DATE=2026-07-06

# Explicit NSE_EQ symbol universe for manual ingestion.
MATSYA_INTRADAY_SYMBOL_UNIVERSE=RELIANCE,HDFCBANK,INFY

# Supply only in the process environment for manual fetches. Never store a real token here.
MATSYA_MANUAL_DHAN_TOKEN=replace_at_runtime
